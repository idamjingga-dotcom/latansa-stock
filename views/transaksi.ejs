<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Transaksi LATANSA</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body class="bg-light">

<div class="container mt-4">

<h2>Transaksi Barang Keluar</h2>

<a href="/dashboard" class="btn btn-secondary mb-3">
Dashboard
</a>

<div class="card p-4 mb-4">

<form method="POST" action="/transaksi/simpan">

<div class="mb-3">
<label>Konsumen</label>

<select
name="customer_id"
class="form-control"
required>

<% customers.forEach(c => { %>
<option value="<%= c.id %>">
<%= c.nama %>
</option>
<% }) %>

</select>
</div>

<div class="mb-3">
<label>Produk</label>

<select
name="product_id"
class="form-control"
required>

<% products.forEach(p => { %>
<option value="<%= p.id %>">
<%= p.nama_produk %> (Stock: <%= p.stock %>)
</option>
<% }) %>

</select>
</div>

<div class="mb-3">
<label>Qty</label>
<input
type="number"
name="qty"
class="form-control"
required>
</div>

<div class="mb-3">
<label>Harga Jual</label>
<input
type="number"
name="harga"
class="form-control"
required>
</div>

<div class="mb-3">
<label>Pembayaran</label>
<input
type="number"
name="bayar"
class="form-control"
value="0">
</div>

<button class="btn btn-primary">
Simpan Transaksi
</button>

</form>

</div>

<hr>

<h3>Riwayat Transaksi</h3>

<table class="table table-bordered table-striped">

<thead>
<tr>
<th>ID</th>
<th>Konsumen</th>
<th>Total</th>
<th>Bayar</th>
<th>Sisa</th>
<th>Status</th>
<th>Invoice</th>
</tr>
</thead>

<tbody>

<% transaksi.forEach(item => { %>

<tr>

<td><%= item.id %></td>

<td><%= item.nama %></td>

<td>
Rp <%= Number(item.total).toLocaleString('id-ID') %>
</td>

<td>
Rp <%= Number(item.bayar).toLocaleString('id-ID') %>
</td>

<td>
Rp <%= Number(item.sisa).toLocaleString('id-ID') %>
</td>

<td>
<span class="badge bg-<%= item.status === 'LUNAS' ? 'success' : 'warning' %>">
<%= item.status %>
</span>
</td>

<td>
<a
href="/invoice/<%= item.id %>"
target="_blank"
class="btn btn-success btn-sm">
Cetak Invoice
</a>
</td>

</tr>

<% }) %>

</tbody>

</table>

</div>

</body>
</html>