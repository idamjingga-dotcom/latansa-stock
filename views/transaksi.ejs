<!DOCTYPE html>
<html>
<head>

<title>Transaksi</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body class="bg-light">

<div class="container mt-4">

<h2>Transaksi Barang Keluar</h2>

<a href="/dashboard" class="btn btn-secondary mb-3">
Dashboard
</a>

<div class="card p-4">

<form method="POST" action="/transaksi/simpan">

<div class="mb-3">

<label>Konsumen</label>

<select
name="customer_id"
class="form-control"
required>

<% customers.forEach(c=>{ %>

<option value="<%= c.id %>">
<%= c.nama %>
</option>

<% }) %>

</select>

</div>

<div class="mb-3">

<label>Produk</label>

<select
name="product_id"
class="form-control"
required>

<% products.forEach(p=>{ %>

<option value="<%= p.id %>">
<%= p.nama_produk %>
(Stok: <%= p.stock %>)
</option>

<% }) %>

</select>

</div>

<div class="mb-3">

<label>Qty</label>

<input
type="number"
name="qty"
class="form-control"
required>

</div>

<div class="mb-3">

<label>Harga Jual</label>

<input
type="number"
name="harga"
class="form-control"
required>

</div>

<div class="mb-3">

<label>Pembayaran</label>

<input
type="number"
name="bayar"
class="form-control"
value="0">

</div>

<button class="btn btn-primary">
Simpan Transaksi
</button>

</form>

</div>

</div>

</body>
</html>