<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Dashboard LATANSA JAYA SNACK</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

body{
background:#f5f6fa;
}

.sidebar{
width:250px;
height:100vh;
background:#111;
position:fixed;
left:0;
top:0;
color:white;
}

.sidebar img{
width:100px;
display:block;
margin:20px auto;
}

.sidebar a{
display:block;
color:white;
padding:12px 20px;
text-decoration:none;
}

.sidebar a:hover{
background:#222;
}

.content{
margin-left:250px;
padding:20px;
}

.card-box{
border:none;
border-radius:15px;
box-shadow:0 3px 10px rgba(0,0,0,.1);
}

</style>
</head>

<body>

<div class="sidebar">

<img src="/logo.png">

<h5 class="text-center">
LATANSA
</h5>

<hr>

<a href="/dashboard">🏠 Dashboard</a>
<a href="/produk">📦 Produk</a>
<a href="/konsumen">👥 Konsumen</a>
<a href="/transaksi">💰 Transaksi</a>
<a href="/piutang">📋 Piutang</a>
<a href="/logout">🚪 Logout</a>
<a href="/laporan">📊 Laporan</a>

</div>

<div class="content">

<h2>Dashboard LATANSA JAYA SNACK</h2>

<div class="row mt-4">

<div class="col-md-3">
<div class="card card-box p-3">
<h5>Total Produk</h5>
<h2><%= totalProduk %></h2>
</div>
</div>

<div class="col-md-3">
<div class="card card-box p-3">
<h5>Total Stock</h5>
<h2><%= totalStock %></h2>
</div>
</div>

<div class="col-md-3">
<div class="card card-box p-3">
<h5>Konsumen</h5>
<h2><%= totalCustomer %></h2>
</div>
</div>

<div class="col-md-3">
<div class="card card-box p-3">
<h5>Omzet</h5>
<h2>
Rp <%= Number(omzet || 0).toLocaleString('id-ID') %>
</h2>
</div>
</div>

</div>

<div class="row mt-3">

<div class="col-md-3">
<div class="card card-box p-3">
<h5>Piutang</h5>
<h2>
Rp <%= Number(piutang || 0).toLocaleString('id-ID') %>
</h2>
</div>
</div>

</div>

</div>

</body>
</html>
