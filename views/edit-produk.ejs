<!DOCTYPE html>
<html>
<head>

<title>Edit Produk</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body class="bg-light">

<div class="container mt-5">

<div class="card p-4">

<h3>Edit Produk</h3>

<form
method="POST"
action="/produk/update/<%= produk.id %>">

<div class="mb-3">

<label>Nama Produk</label>

<input
name="nama_produk"
class="form-control"
value="<%= produk.nama_produk %>">

</div>

<div class="mb-3">

<label>Harga</label>

<input
name="harga"
type="number"
class="form-control"
value="<%= produk.harga %>">

</div>

<button class="btn btn-primary">
Simpan
</button>

<a href="/produk" class="btn btn-secondary">
Kembali
</a>

</form>

</div>

</div>

</body>
</html>