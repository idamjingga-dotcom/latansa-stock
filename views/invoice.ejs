<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Invoice LATANSA</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

body{
background:#f2f4f8;
font-family:Arial, sans-serif;
}

.invoice-box{
max-width:900px;
margin:30px auto;
background:white;
padding:40px;
border-radius:15px;
box-shadow:0 5px 20px rgba(0,0,0,.15);
}

.header{
display:flex;
justify-content:space-between;
align-items:center;
border-bottom:2px solid #eee;
padding-bottom:20px;
margin-bottom:25px;
}

.logo{
width:100px;
}

.company{
text-align:right;
}

.company h2{
margin:0;
font-weight:bold;
}

.invoice-title{
font-size:32px;
font-weight:bold;
color:#111;
}

.table th{
background:#111;
color:white;
}

.total-box{
background:#f8f9fa;
padding:20px;
border-radius:10px;
margin-top:20px;
}

.total{
font-size:30px;
font-weight:bold;
color:#198754;
}

.badge-status{
font-size:16px;
padding:10px 15px;
}

.print-btn{
margin-bottom:20px;
}

@media print{

.print-btn{
display:none;
}

body{
background:white;
}

.invoice-box{
box-shadow:none;
margin:0;
max-width:100%;
}

}

</style>
</head>

<body>

<div class="container">

<div class="text-center print-btn">
<button onclick="window.print()" class="btn btn-success btn-lg">
🖨 Cetak Invoice
</button>
</div>

<div class="invoice-box">

<div class="header">

<div>
<img src="/logo.png" class="logo">
</div>

<div class="company">
<h2>LATANSA JAYA SNACK</h2>
<p>
Cikoneng - Ciamis<br>
Jawa Barat
</p>
</div>

</div>

<div class="row mb-4">

<div class="col-md-6">
<h3 class="invoice-title">
INVOICE
</h3>

<p>
No Invoice :
<b>#<%= trx.id %></b>
</p>

<p>
Tanggal :
<b>
<%= new Date(trx.created_at).toLocaleDateString("id-ID") %>
</b>
</p>
</div>

<div class="col-md-6 text-end">

<h5>Konsumen</h5>

<h3>
<%= trx.nama %>
</h3>

</div>

</div>

<table class="table table-bordered">

<thead>
<tr>
<th>Produk</th>
<th>Qty</th>
<th>Harga</th>
<th>Subtotal</th>
</tr>
</thead>

<tbody>

<% items.forEach(item => { %>

<tr>
<td><%= item.nama_produk %></td>

<td><%= item.qty %></td>

<td>
Rp <%= Number(item.harga).toLocaleString('id-ID') %>
</td>

<td>
Rp <%= Number(item.subtotal).toLocaleString('id-ID') %>
</td>
</tr>

<% }) %>

</tbody>

</table>

<div class="row">

<div class="col-md-6">

<p>
Status :
<% if(trx.status=="LUNAS"){ %>

<span class="badge bg-success badge-status">
LUNAS
</span>

<% } else { %>

<span class="badge bg-danger badge-status">
BELUM LUNAS
</span>

<% } %>
</p>

</div>

<div class="col-md-6">

<div class="total-box">

<p>
Total Tagihan
</p>

<div class="total">
Rp <%= Number(trx.total).toLocaleString('id-ID') %>
</div>

<hr>

<p>
Bayar :
Rp <%= Number(trx.bayar).toLocaleString('id-ID') %>
</p>

<p>
Sisa :
Rp <%= Number(trx.sisa).toLocaleString('id-ID') %>
</p>

</div>

</div>

</div>

<div class="mt-5 text-center text-muted">

Terima kasih telah berbelanja di
<b>LATANSA JAYA SNACK</b>

</div>

</div>

</div>

</body>
</html>