<!DOCTYPE html>
<html>
<head>

<title>Bayar Piutang</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body class="bg-light">

<div class="container mt-5">

<div class="card p-4">

<h3>Pembayaran Piutang</h3>

<p>
Sisa Hutang:
<b>
Rp <%= Number(trx.sisa).toLocaleString('id-ID') %>
</b>
</p>

<form
method="POST"
action="/piutang/bayar/<%= trx.id %>">

<input
type="number"
name="nominal"
class="form-control mb-3"
placeholder="Nominal Pembayaran"
required>

<button class="btn btn-success">
Simpan Pembayaran
</button>

</form>

</div>

</div>

</body>
</html>