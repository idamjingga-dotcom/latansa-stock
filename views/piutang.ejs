<!DOCTYPE html>
<html>
<head>

<title>Piutang</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body class="bg-light">

<div class="container mt-4">

<h2>Daftar Piutang Konsumen</h2>

<a href="/dashboard" class="btn btn-secondary mb-3">
Dashboard
</a>

<table class="table table-bordered bg-white">

<thead>

<tr>

<th>ID</th>
<th>Konsumen</th>
<th>Total</th>
<th>Bayar</th>
<th>Sisa</th>
<th>Status</th>
<th>Aksi</th>

</tr>

</thead>

<tbody>

<% data.forEach(item=>{ %>

<tr>

<td><%= item.id %></td>

<td><%= item.nama %></td>

<td>Rp <%= Number(item.total).toLocaleString('id-ID') %></td>

<td>Rp <%= Number(item.bayar).toLocaleString('id-ID') %></td>

<td>Rp <%= Number(item.sisa).toLocaleString('id-ID') %></td>

<td>

<% if(item.status=="LUNAS"){ %>

<span class="badge bg-success">
LUNAS
</span>

<% } else { %>

<span class="badge bg-danger">
BELUM LUNAS
</span>

<% } %>

</td>

<td>

<% if(item.status!="LUNAS"){ %>

<a
href="/piutang/bayar/<%= item.id %>"
class="btn btn-primary btn-sm">
Bayar
</a>

<% } %>

</td>

</tr>

<% }) %>

</tbody>

</table>

</div>

</body>
</html>