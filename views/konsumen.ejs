<!DOCTYPE html>
<html>
<head>

<title>Konsumen</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body class="bg-light">

<div class="container mt-4">

<h2>Data Konsumen</h2>

<a href="/dashboard" class="btn btn-secondary mb-3">
Dashboard
</a>

<div class="card p-3 mb-3">

<form method="POST" action="/konsumen/tambah">

<div class="row">

<div class="col-md-4">
<input
name="nama"
class="form-control"
placeholder="Nama Konsumen"
required>
</div>

<div class="col-md-4">
<input
name="alamat"
class="form-control"
placeholder="Alamat">
</div>

<div class="col-md-2">
<input
name="telepon"
class="form-control"
placeholder="Telepon">
</div>

<div class="col-md-2">
<button class="btn btn-success w-100">
Tambah
</button>
</div>

</div>

</form>

</div>

<table class="table table-bordered bg-white">

<thead>
<tr>
<th>ID</th>
<th>Nama</th>
<th>Alamat</th>
<th>Telepon</th>
</tr>
</thead>

<tbody>

<% customers.forEach(item=>{ %>

<tr>

<td><%= item.id %></td>
<td><%= item.nama %></td>
<td><%= item.alamat %></td>
<td><%= item.telepon %></td>

</tr>

<% }) %>

</tbody>

</table>

</div>

</body>
</html>