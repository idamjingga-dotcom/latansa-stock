<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>LATANSA JAYA SNACK</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
body{
background:#111;
height:100vh;
display:flex;
justify-content:center;
align-items:center;
}

.card{
width:400px;
padding:20px;
border-radius:20px;
}

.logo{
width:120px;
display:block;
margin:auto;
}
</style>
</head>

<body>

<div class="card bg-white shadow">

<img src="/logo.png" class="logo">

<h3 class="text-center mt-3">
LATANSA JAYA SNACK
</h3>

<form method="POST" action="/login">

<input
class="form-control mt-3"
name="username"
placeholder="Username"
required>

<input
type="password"
class="form-control mt-3"
name="password"
placeholder="Password"
required>

<button class="btn btn-dark w-100 mt-3">
Login
</button>

</form>

</div>

</body>
</html>