<!DOCTYPE html>
<html>
<head>

<meta charset="UTF-8">

<title>Produk LATANSA</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body class="bg-light">

<div class="container mt-4">

<h2>Data Produk LATANSA</h2>

<a href="/dashboard" class="btn btn-secondary mb-3">
Kembali Dashboard
</a>

<div class="card p-3 mb-4">

<form method="POST" action="/produk/tambah">

<div class="row">

<div class="col-md-4">
<input
name="nama_produk"
class="form-control"
placeholder="Nama Produk"
required>
</div>

<div class="col-md-3">
<input
name="harga"
type="number"
class="form-control"
placeholder="Harga"
required>
</div>

<div class="col-md-3">
<input
name="stock"
type="number"
class="form-control"
placeholder="Stock Awal"
required>
</div>

<div class="col-md-2">

<button class="btn btn-success w-100">
Tambah
</button>

</div>

</div>

</form>

</div>

<table class="table table-bordered bg-white">

<thead>

<tr>

<th>ID</th>

<th>Produk</th>

<th>Harga</th>

<th>Stock</th>
<th>Aksi</th>
</tr>

</thead>

<tbody>

<% products.forEach(item=>{ %>

<tr>

<td><%= item.id %></td>

<td><%= item.nama_produk %></td>

<td>Rp <%= Number(item.harga).toLocaleString('id-ID') %></td>

<td><%= item.stock %></td> 
<td>

<a
href="/produk/edit/<%= item.id %>"
class="btn btn-warning btn-sm">
Edit
</a>

<a
href="/stock/tambah/<%= item.id %>"
class="btn btn-success btn-sm">
+ Stock
</a>

<a
href="/stock/kurang/<%= item.id %>"
class="btn btn-danger btn-sm">
- Stock
</a>

<a
href="/produk/hapus/<%= item.id %>"
class="btn btn-dark btn-sm"
onclick="return confirm('Hapus produk?')">
Hapus
</a>

</td>

</tr>

<% }) %>

</tbody>

</table>

</div>

</body>
</html>